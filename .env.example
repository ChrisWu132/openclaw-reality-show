GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash
PORT=3001
NODE_ENV=development
DEBUG_WRITE_LOGS=true
LOG_LEVEL=info

# OpenClaw API — port for the openclaw service itself
# URL + key used by the reality show server to call the openclaw service
# Without agentId in session create requests, falls back to coordinator-default.md
OPENCLAW_PORT=3002
OPENCLAW_API_URL=http://localhost:3002
OPENCLAW_API_KEY=dev-openclaw-key-local

# Presaige API — optional, enables "Surveillance Assessment" on consequence screen
# Get a key at https://presaige.ai
PRESAIGE_API_KEY=your-presaige-api-key-here

# ElevenLabs TTS — optional. Leave blank to disable voice narration entirely.
# Get a key at https://elevenlabs.io (free tier: 10k chars/month)
ELEVENLABS_API_KEY=

# Voice ID overrides — optional. Defaults are pre-selected for each character role.
# Find voice IDs at https://elevenlabs.io/voice-library or via the ElevenLabs API.
# ELEVENLABS_VOICE_NARRATOR=bIHbv24MWmeRgasZH58o      # Will — deep, storytelling
# ELEVENLABS_VOICE_COORDINATOR=pNInz6obpgDQGcFmaJgB   # Adam — authoritative
# ELEVENLABS_VOICE_MONITOR=CwhRBWXzGAHq8TQ4Fs17       # Roger — flat, data-centric
# ELEVENLABS_VOICE_NYX=21m00Tcm4TlvDq8ikWAM            # Rachel — resigned
# ELEVENLABS_VOICE_SABLE=AZnzlk1XvdvUeBnXmlld         # Domi — crisp
# ELEVENLABS_VOICE_CALLA=jsCqWAovK2LkecY7zXl4         # Freya — soft
# ELEVENLABS_VOICE_ELI=TxGEqnHWrfWFTfGW9XjX           # Josh — grounded

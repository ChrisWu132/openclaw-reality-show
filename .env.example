GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash
PORT=3001
NODE_ENV=development
DEBUG_WRITE_LOGS=true
LOG_LEVEL=info

# Auth — set AUTH_REQUIRED=true to enforce login + delegation tokens
AUTH_REQUIRED=false
JWT_SECRET=change-me-to-a-random-string
JWT_DELEGATION_SECRET=change-me-delegation-secret
